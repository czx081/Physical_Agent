# Copy this file to .env for real Xiaozhi MCP hardware.
# Keep .env out of git.

# For direct LAN MCP over WebSocket, use the robot's local /ws endpoint.
XIAOZHI_MCP_URL=ws://192.168.66.237:8080/ws

# You can also provide host/port/path separately instead of XIAOZHI_MCP_URL.
XIAOZHI_MCP_HOST=192.168.66.237
XIAOZHI_MCP_PORT=8080
XIAOZHI_MCP_PATH=/ws

# If your Xiaozhi MCP endpoint is an HTTP JSON-RPC bridge instead, use it directly.
XIAOZHI_MCP_ENDPOINT=http://127.0.0.1:3000/mcp

# Optional bearer token if your bridge requires one.
XIAOZHI_MCP_TOKEN=
